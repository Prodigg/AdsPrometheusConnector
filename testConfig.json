{
  "global": {
    "localNetId": "192.168.1.126.1.1",
    "remoteNetId": "5.109.7.180.1.1",
    "remoteIp": "plc-raphael.localdomain",
    "httpPort": 9080,
    "pollTimeResolution": 500
  },

  "NodeRed.bIsLightOn": {
    "alias": "isLightOn",
    "type": "untyped",
    "description": "is the light on",
    "ADSDatatype": "BOOL",
    "scrapingTime": 1,
    "labels": {
      "testLabel": {
        "value": "This is the first label"
      },
      "secondLabel": {
        "value": "This is the second label"
      }
    }
  },

  "NodeRed.bDoNotDisturbStatus": {
    "ADSDatatype": "BOOL",
    "scrapingTime": 1.5,

    "currentLastTime": {
      "show": true,
      "carryLabels": true,
      "alias": "",
      "customDescription": "customDescription"
    },
    "readTime": {
      "show": true,
      "carryLabels": false,
      "alias": "readTimeDoNotDisturb",
      "labels": {
        "testLabel": {
          "value": "labelValue"
        }
      }
    }
  },
  "GrafanaExporter.bDoNotDisturb": {
    "alias": "bDoNotDisturb2",
    "ADSDatatype": "BOOL",
    "scrapingTime": 1
  }
}
